# ── Workers AI (default, uses your Cloudflare account's AI binding) ────────────
AI_PROVIDER=workers-ai
# AI_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast

# ── Groq (recommended backup when Workers AI rate limits hit) ──────────────────
# Sign up at https://console.groq.com → API Keys → Create key
# AI_PROVIDER=groq
# AI_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
# AI_MODEL=llama-3.3-70b-versatile
# (base URL is set automatically for groq — no AI_BASE_URL needed)

# ── Generic OpenAI-compatible (OpenRouter, Together, etc.) ────────────────────
# AI_PROVIDER=openai-compatible
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_API_KEY=your_api_key
# AI_MODEL=llama-3.3-70b-versatile

# ── Gemini via OpenAI compatibility endpoint ───────────────────────────────────
# AI_PROVIDER=openai-compatible
# AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# AI_API_KEY=your_google_ai_key
# AI_MODEL=gemini-2.0-flash

# Optional - Cloudflare AI Gateway https://developers.cloudflare.com/ai-gateway/
# GATEWAY_BASE_URL=https://gateway.ai.cloudflare.com/v1/..
# GREENHOUSE_API_KEY=your_key_here