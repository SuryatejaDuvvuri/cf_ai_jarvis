{
  "name": "@panelai/worker",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite dev --force",
    "build": "vite build",
    "check": "prettier \"{src,__tests__}/**/*.{ts,tsx}\" env.d.ts package.json tsconfig.json vite.config.ts vitest.config.ts wrangler.jsonc wrangler.staging.jsonc wrangler.production.jsonc --check && biome lint src __tests__ env.d.ts && tsc --noEmit",
    "test": "vitest run",
    "deploy": "vite build && wrangler deploy",
    "deploy:staging": "vite build && wrangler deploy --config wrangler.staging.jsonc",
    "deploy:prod": "vite build && wrangler deploy --config wrangler.production.jsonc"
  },
  "dependencies": {
    "@panelai/shared": "*",
    "@panelai/core": "*",
    "@panelai/agents": "*",
    "@panelai/frontend": "*",
    "@ai-sdk/openai": "^3.0.2",
    "@ai-sdk/react": "^3.0.5",
    "@cloudflare/ai-chat": "^0.0.4",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "agents": "^0.3.3",
    "ai": "^6.0.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "marked": "^17.0.1",
    "mermaid": "^11.12.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "streamdown": "^2.1.0",
    "tailwind-merge": "^3.4.0",
    "workers-ai-provider": "^3.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@cloudflare/vite-plugin": "^1.21.2",
    "@cloudflare/vitest-pool-workers": "^0.12.6",
    "@cloudflare/workers-types": "^4.20251231.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "3.2.4",
    "wrangler": "^4.60.0"
  }
}
